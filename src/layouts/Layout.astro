---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Cara simpel buat invoice, 1 menit langsung jadi.",
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Umami Analytics -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="1fec51f5-28a0-4a25-b825-63c47808d7b8"></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Sinvois | {title}</title>
  </head>
  <body class="min-h-screen bg-bg">
    <slot />
  </body>
</html>
