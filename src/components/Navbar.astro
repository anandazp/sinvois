---
interface Props {
  variant?: "landing" | "app";
}
const { variant = "landing" } = Astro.props;
---

<header class="w-full px-6 py-4 relative">
  <nav class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="font-heading font-bold text-lg text-primary">Sinvois</a>
    {
      variant === "landing" ? (
        <>
          <div class="hidden md:flex items-center gap-8 text-secondary text-base">
            <a href="/" class="hover:text-primary transition-colors">
              Beranda
            </a>
            <a href="#fitur" class="hover:text-primary transition-colors">
              Fitur
            </a>
            <a href="#faq" class="hover:text-primary transition-colors">
              FAQ
            </a>
          </div>
          <div class="hidden md:flex items-center gap-8">
            <a href="/create" class="nav-cta">
              Buat Invois
            </a>
          </div>
          <button
            id="nav-toggle"
            class="md:hidden flex flex-col gap-1.5 p-1 cursor-pointer"
            aria-label="Toggle menu"
          >
            <span class="hamburger-line" />
            <span class="hamburger-line" />
            <span class="hamburger-line" />
          </button>
        </>
      ) : (
        <div class="flex items-center gap-6 text-secondary text-base">
          <a href="/" class="hover:text-primary transition-colors">
            Beranda
          </a>
        </div>
      )
    }
  </nav>

  {
    variant === "landing" && (
      <div id="mobile-menu" class="mobile-menu md:hidden">
        <div class="max-w-6xl mx-auto flex flex-col gap-4 py-4">
          <a
            href="/"
            class="text-secondary hover:text-primary transition-colors"
            id="mobile-beranda"
          >
            Beranda
          </a>
          <a
            href="#fitur"
            class="text-secondary hover:text-primary transition-colors"
            id="mobile-fitur"
          >
            Fitur
          </a>
          <a
            href="#faq"
            class="text-secondary hover:text-primary transition-colors"
            id="mobile-faq"
          >
            FAQ
          </a>
          <a href="/create" class="nav-cta self-start">
            Buat Invois
          </a>
        </div>
      </div>
    )
  }
</header>

<script is:inline>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      menu.classList.toggle("open");
    });
    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => menu.classList.remove("open"));
    });
  }
</script>

<style>
  .nav-cta {
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-heading);
    font-weight: 600;
    transition:
      background-color 0.15s,
      color 0.15s;
    cursor: pointer;
    border-radius: 2px;
  }
  .nav-cta:hover {
    background-color: var(--color-primary);
    color: var(--color-bg);
  }
  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: 2px;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }
  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .mobile-menu.open {
    max-height: 300px;
  }
</style>
